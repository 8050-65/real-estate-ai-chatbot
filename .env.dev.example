# ============================================================
# DEV ENVIRONMENT VARIABLES
# ============================================================
# Copy this file to .env.dev and fill in actual values
# Never commit .env.dev to repository
# ============================================================

# ============================================================
# FRONTEND CONFIGURATION
# ============================================================
NEXT_PUBLIC_API_URL=https://dev-api.example.in
NEXT_PUBLIC_RAG_URL=https://dev-rag.example.in
NEXT_PUBLIC_APP_NAME=RealEstate AI CRM - Dev
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_LOG_LEVEL=debug

# ============================================================
# DATABASE CONFIGURATION
# ============================================================
DATABASE_HOST=db-dev.render.onrender.com
DATABASE_PORT=5432
DATABASE_NAME=crm_cbt_db_dev
DATABASE_USER=devuser
DATABASE_PASSWORD=<CHANGE_ME_SECURE_PASSWORD>
DATABASE_POOL_SIZE=10
DATABASE_TIMEOUT=30

# Database URL (alternative format)
DATABASE_URL=postgresql://devuser:<CHANGE_ME>@db-dev.render.onrender.com:5432/crm_cbt_db_dev

# ============================================================
# REDIS CONFIGURATION (Upstash)
# ============================================================
REDIS_URL=redis://<UPSTASH_REDIS_URL>
REDIS_HOST=<UPSTASH_REDIS_HOST>
REDIS_PORT=<UPSTASH_REDIS_PORT>
REDIS_PASSWORD=<UPSTASH_REDIS_PASSWORD>
REDIS_DB=0
REDIS_TIMEOUT=30
REDIS_CACHE_TTL=3600

# ============================================================
# JAVA BACKEND CONFIGURATION
# ============================================================
SPRING_PROFILES_ACTIVE=dev
SPRING_JPA_HIBERNATE_DDL_AUTO=validate
SPRING_JPA_SHOW_SQL=false
SPRING_JPA_PROPERTIES_HIBERNATE_FORMAT_SQL=true
SERVER_SERVLET_CONTEXT_PATH=/api/v1
SERVER_PORT=8080

# ============================================================
# JWT & SECURITY
# ============================================================
JWT_SECRET=<CHANGE_ME_LONG_RANDOM_STRING_MIN_32_CHARS>
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ============================================================
# LEADRAT INTEGRATION
# ============================================================
LEADRAT_API_KEY=<YOUR_LEADRAT_API_KEY>
LEADRAT_TENANT=dubaitt11
LEADRAT_API_BASE_URL=https://api.leadrat.com
LEADRAT_TIMEOUT=30

# ============================================================
# FASTAPI/RAG CONFIGURATION
# ============================================================
ENVIRONMENT=development
PYTHONUNBUFFERED=1
LOG_LEVEL=INFO
UVICORN_WORKERS=2
UVICORN_TIMEOUT=30

# ============================================================
# OLLAMA / LLM CONFIGURATION
# ============================================================
OLLAMA_HOST=http://ollama:11434
OLLAMA_MODEL=llama2
OLLAMA_TIMEOUT=60
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9

# ============================================================
# VECTOR DATABASE (Upstash Vector)
# ============================================================
VECTOR_DB_URL=<UPSTASH_VECTOR_URL>
VECTOR_DB_TOKEN=<UPSTASH_VECTOR_TOKEN>
VECTOR_DIMENSION=1536
VECTOR_SIMILARITY_THRESHOLD=0.7
VECTOR_MAX_RESULTS=10

# ============================================================
# CORS CONFIGURATION
# ============================================================
CORS_ALLOWED_ORIGINS=https://dev-chatbot.example.in,https://dev-api.example.in
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,DELETE,OPTIONS,PATCH
CORS_ALLOW_HEADERS=Content-Type,Authorization,Accept

# ============================================================
# LOGGING & MONITORING
# ============================================================
LOG_FORMAT=json
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG
LOG_RETENTION_DAYS=7

# Application Insights (optional)
APPLICATIONINSIGHTS_CONNECTION_STRING=<IF_USING_APP_INSIGHTS>
APPINSIGHTS_ENABLED=false

# ============================================================
# EMAIL CONFIGURATION (optional)
# ============================================================
MAIL_SERVER=<SMTP_SERVER>
MAIL_PORT=587
MAIL_USERNAME=<MAIL_USERNAME>
MAIL_PASSWORD=<MAIL_PASSWORD>
MAIL_FROM=noreply@dev-example.in
MAIL_ENCRYPTION=tls

# ============================================================
# STORAGE CONFIGURATION
# ============================================================
STORAGE_TYPE=local
STORAGE_PATH=/data/uploads
MAX_UPLOAD_SIZE=104857600

# ============================================================
# SERVICE URLS
# ============================================================
FRONTEND_URL=https://dev-chatbot.example.in
API_URL=https://dev-api.example.in
RAG_URL=https://dev-rag.example.in
ADMIN_URL=https://dev-docs.example.in

# ============================================================
# FEATURE FLAGS
# ============================================================
FEATURE_AI_CHAT=true
FEATURE_LEAD_MANAGEMENT=true
FEATURE_APPOINTMENTS=true
FEATURE_MULTILINGUAL=true
FEATURE_RAG_PIPELINE=true
FEATURE_VECTOR_SEARCH=true

# ============================================================
# RATE LIMITING
# ============================================================
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# ============================================================
# BACKUP & RECOVERY
# ============================================================
BACKUP_ENABLED=true
BACKUP_SCHEDULE=0 2 * * *
BACKUP_RETENTION_DAYS=30
BACKUP_ENCRYPTION=true

# ============================================================
# NODE.JS / APPLICATION
# ============================================================
NODE_ENV=development
NODE_OPTIONS=--max-old-space-size=512

# ============================================================
# DEPLOYMENT INFORMATION
# ============================================================
ENVIRONMENT_NAME=Development
DEPLOYED_DATE=2026-04-29
DEPLOYMENT_REGION=oregon
DEPLOYMENT_PROVIDER=vercel,render,upstash
