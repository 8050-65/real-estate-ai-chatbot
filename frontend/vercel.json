{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "API endpoint for Java backend",
      "required": true,
      "default": "https://dev-api.example.in"
    },
    "NEXT_PUBLIC_RAG_URL": {
      "description": "FastAPI/RAG endpoint",
      "required": true,
      "default": "https://dev-rag.example.in"
    },
    "NEXT_PUBLIC_APP_NAME": {
      "description": "Application name",
      "required": false,
      "default": "RealEstate AI CRM"
    },
    "NEXT_PUBLIC_ENVIRONMENT": {
      "description": "Environment type",
      "required": false,
      "default": "development"
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
