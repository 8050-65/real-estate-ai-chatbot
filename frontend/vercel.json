{
  "name": "real-estate-ai-chatbot-frontend",
  "version": 2,
  "public": false,
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "env": {
    "NEXT_PUBLIC_API_URL": {
      "description": "API endpoint for Java backend",
      "required": true,
      "default": "https://dev-api.example.in"
    },
    "NEXT_PUBLIC_RAG_URL": {
      "description": "FastAPI/RAG endpoint",
      "required": true,
      "default": "https://dev-rag.example.in"
    },
    "NEXT_PUBLIC_APP_NAME": {
      "description": "Application name",
      "required": false,
      "default": "RealEstate AI CRM"
    },
    "NEXT_PUBLIC_ENVIRONMENT": {
      "description": "Environment type",
      "required": false,
      "default": "development"
    }
  },
  "envs": {
    "development": {
      "NEXT_PUBLIC_API_URL": "https://dev-api.example.in",
      "NEXT_PUBLIC_RAG_URL": "https://dev-rag.example.in",
      "NEXT_PUBLIC_ENVIRONMENT": "development"
    }
  },
  "git": {
    "silent": false
  },
  "regions": ["iad1"],
  "functions": {
    "api/**/*.ts": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/next"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/",
      "status": 200
    }
  ],
  "redirects": [],
  "rewrites": [],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/static/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
