version: '3.9'

services:
  postgres:
    image: postgres:15-alpine
    container_name: crm-postgres
    environment:
      POSTGRES_DB: crm_cbt_db_dev
      POSTGRES_USER: rootuser
      POSTGRES_PASSWORD: "123Pa$$word!"
    ports:
      - "5432:5432"
    volumes:
      - postgres_data:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U rootuser -d crm_cbt_db_dev"]
      interval: 10s
      timeout: 5s
      retries: 5
    networks:
      - realestate-network
    restart: unless-stopped

  pgadmin:
    image: dpage/pgadmin4:latest
    container_name: crm-pgadmin
    environment:
      PGADMIN_DEFAULT_EMAIL: admin@crm.com
      PGADMIN_DEFAULT_PASSWORD: admin123
    ports:
      - "5050:80"
    depends_on:
      - postgres
    networks:
      - realestate-network
    restart: unless-stopped

  redis:
    image: redis:7-alpine
    container_name: realestate_redis
    ports:
      - "${REDIS_PORT:-6379}:6379"
    volumes:
      - redis_data:/data
    networks:
      - realestate-network
    command: redis-server --appendonly yes
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
    restart: unless-stopped

  ollama:
    image: ollama/ollama:latest
    container_name: realestate_ollama
    ports:
      - "${OLLAMA_PORT:-11434}:11434"
    volumes:
      - ollama_models:/root/.ollama
    networks:
      - realestate-network
    environment:
      OLLAMA_HOST: 0.0.0.0:11434
    healthcheck:
      test: ["CMD-SHELL", "ollama list || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  backend-ai:
    build:
      context: ./backend-ai
      dockerfile: Dockerfile
    container_name: realestate_backend_ai
    environment:
      DATABASE_URL: postgresql+asyncpg://${DB_USER:-rootuser}:${DB_PASSWORD:-123Pa$$word!}@postgres:5432/${DB_NAME:-crm_cbt_db_dev}
      REDIS_URL: redis://redis:6379
      OLLAMA_BASE_URL: http://ollama:11434
      OLLAMA_MODEL: ${OLLAMA_MODEL:-llama3.2}
      SPRING_BOOT_URL: http://backend-java:8080
      LEADRAT_BASE_URL: ${LEADRAT_BASE_URL:-https://connect.leadrat.info/api/v1}
      LEADRAT_AUTH_URL: ${LEADRAT_AUTH_URL:-https://connect.leadrat.com/api/v1/authentication/token}
      LEADRAT_TENANT: ${LEADRAT_TENANT:-black}
      LEADRAT_API_KEY: ${LEADRAT_API_KEY}
      LEADRAT_SECRET_KEY: ${LEADRAT_SECRET_KEY}
      ENGAGETO_TOKEN: ${ENGAGETO_TOKEN}
      ENGAGETO_PHONE_ID: ${ENGAGETO_PHONE_ID}
      ENGAGETO_WEBHOOK_SECRET: ${ENGAGETO_WEBHOOK_SECRET}
      JWT_SECRET_KEY: ${JWT_SECRET_KEY}
      CHROMA_DB_PATH: ./chroma_db
      LOG_LEVEL: ${LOG_LEVEL:-INFO}
      ENVIRONMENT: development
    ports:
      - "${AI_SERVICE_PORT:-8000}:8000"
    volumes:
      - ./backend-ai:/app
      - chroma_data:/app/chroma_db
    networks:
      - realestate-network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      ollama:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  backend-java:
    build:
      context: ./backend-java
      dockerfile: Dockerfile
    container_name: realestate_backend_java
    env_file:
      - ./backend-java/.env
    environment:
      SPRING_DATASOURCE_URL: jdbc:postgresql://postgres:5432/${DB_NAME:-crm_cbt_db_dev}
      SPRING_DATASOURCE_USERNAME: ${DB_USER:-rootuser}
      SPRING_DATASOURCE_PASSWORD: ${DB_PASSWORD:-123Pa$$word!}
      SPRING_REDIS_HOST: redis
      SPRING_REDIS_PORT: 6379
      SPRING_JPA_HIBERNATE_DDL_AUTO: update
      LEADRAT_BASE_URL: ${LEADRAT_BASE_URL:-https://connect.leadrat.info/api/v1}
      LEADRAT_AUTH_URL: ${LEADRAT_AUTH_URL:-https://connect.leadrat.com/api/v1/authentication/token}
      LEADRAT_TENANT: ${LEADRAT_TENANT:-dubait11}
      LEADRAT_API_KEY: ${LEADRAT_API_KEY}
      LEADRAT_SECRET_KEY: ${LEADRAT_SECRET_KEY}
      FASTAPI_URL: http://backend-ai:8000
      JWT_SECRET_KEY: default_jwt_secret_key_minimum_32_characters_secure_key_abc123xyz789
      JWT_EXPIRATION: 86400000
      SERVER_PORT: 8080
      ENVIRONMENT: development
    ports:
      - "${BACKEND_PORT:-8080}:8080"
    networks:
      - realestate-network
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_healthy
      backend-ai:
        condition: service_healthy
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8080/actuator/health"]
      interval: 30s
      timeout: 10s
      retries: 3
    restart: unless-stopped

  # frontend:
  #   build:
  #     context: ./frontend
  #     dockerfile: Dockerfile
  #   container_name: realestate_frontend
  #   environment:
  #     NEXT_PUBLIC_API_URL: http://localhost:8080
  #     NEXT_PUBLIC_APP_NAME: RealEstate AI CRM
  #     NEXT_PUBLIC_APP_VERSION: 1.0.0
  #   ports:
  #     - "${FRONTEND_PORT:-3000}:3000"
  #   networks:
  #     - realestate-network
  #   depends_on:
  #     - backend-java
  #   healthcheck:
  #     test: ["CMD", "curl", "-f", "http://localhost:3000"]
  #     interval: 30s
  #     timeout: 10s
  #     retries: 3
  #   restart: unless-stopped

volumes:
  postgres_data:
    driver: local
  redis_data:
    driver: local
  ollama_models:
    driver: local
  chroma_data:
    driver: local

networks:
  realestate-network:
    driver: bridge
