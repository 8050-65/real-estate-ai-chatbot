# ============================================================================
# FastAPI AI Service Environment Configuration
# ============================================================================
# Copy this file to .env and fill in actual values
# NEVER commit .env to git - it is in .gitignore

# ============================================================================
# Database Configuration
# ============================================================================
DATABASE_URL=postgresql+asyncpg://realestate:password@postgres:5432/realestate_db

# ============================================================================
# Redis Configuration (Session Cache & Token Storage)
# ============================================================================
REDIS_URL=redis://redis:6379
REDIS_DB=0
REDIS_TTL_SECONDS=300

# ============================================================================
# LLM Provider Selection & Configuration
# ============================================================================
# Default: "ollama" (local, free, no API key required)
# Options: "ollama", "groq", "openai", "gemini"
# Change only the LLM_PROVIDER value to switch providers
# Only .env change needed - no code modifications required
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=3

# ============================================================================
# Ollama Configuration (Local LLM - DEFAULT)
# ============================================================================
# Required when LLM_PROVIDER=ollama
# Run locally: docker-compose up ollama
# Models: llama3.2, mistral, neural-chat, etc.
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# Groq API Configuration (Optional - Cloud LLM for testing)
# ============================================================================
# Required when LLM_PROVIDER=groq
# Get API key: https://console.groq.com
# Free tier available with rate limits
# Popular models: mixtral-8x7b-32768, llama-2-70b, gemma-7b-it
GROQ_API_KEY=
GROQ_MODEL=mixtral-8x7b-32768

# ============================================================================
# OpenAI API Configuration (Optional - Cloud LLM for testing)
# ============================================================================
# Required when LLM_PROVIDER=openai
# Get API key: https://platform.openai.com/api-keys
# Models: gpt-4-turbo, gpt-4, gpt-3.5-turbo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4-turbo
OPENAI_BASE_URL=https://api.openai.com/v1

# ============================================================================
# Google Gemini Configuration (Optional - Cloud LLM for testing)
# ============================================================================
# Required when LLM_PROVIDER=gemini
# Get API key: https://ai.google.dev
# Free tier available
# Models: gemini-pro, gemini-1.5-pro
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-pro

# ============================================================================
# Leadrat CRM Integration
# ============================================================================
LEADRAT_BASE_URL=https://connect.leadrat.info/api/v1
LEADRAT_AUTH_URL=https://connect.leadrat.com/api/v1/authentication/token
LEADRAT_TENANT=dubait11
LEADRAT_API_KEY=Zjg2N2JiNjItODBmOC00YzBjLTlkMmMtMjk5OGRiZjBmMDU3OmR1YmFpdDEx
LEADRAT_SECRET_KEY=a3Ay5UKLYjm6sZ_TXCXGzqmIdB3zgM8Y
LEADRAT_TOKEN_CACHE_TTL=3600

# ============================================================================
# Engageto WhatsApp Business API
# ============================================================================
ENGAGETO_TOKEN=your_engageto_bearer_token_here
ENGAGETO_PHONE_ID=your_whatsapp_phone_id_here
ENGAGETO_WEBHOOK_SECRET=your_webhook_signature_secret_here
ENGAGETO_API_BASE_URL=https://api.engageto.com/v1

# ============================================================================
# Spring Boot Backend Integration
# ============================================================================
SPRING_BOOT_URL=http://backend-java:8080
SPRING_BOOT_TIMEOUT_SECONDS=30

# ============================================================================
# JWT & Security
# ============================================================================
JWT_SECRET_KEY=your_jwt_secret_minimum_32_chars_long_minimum_32_chars_long
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Chroma Vector Database (RAG)
# ============================================================================
CHROMA_DB_PATH=./chroma_db
CHROMA_PERSIST_DIRECTORY=./chroma_db

# ============================================================================
# Application Configuration
# ============================================================================
LOG_LEVEL=INFO
ENVIRONMENT=development
DEBUG=False

# ============================================================================
# CORS Configuration
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ============================================================================
# Rate Limiting
# ============================================================================
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# Session Configuration
# ============================================================================
SESSION_TIMEOUT_HOURS=24
CONVERSATION_HISTORY_LIMIT=20

# ============================================================================
# Monitoring & Observability
# ============================================================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1
