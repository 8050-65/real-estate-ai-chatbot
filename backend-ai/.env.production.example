# ============================================================================
# PRODUCTION ENVIRONMENT - FastAPI Backend
# ============================================================================
# Copy this to .env and replace placeholder values with actual production values

# ============================================================================
# Environment Detection
# ============================================================================
ENVIRONMENT=production
DEBUG=False
LOG_LEVEL=WARNING

# ============================================================================
# LLM Provider Selection (Use Ollama or Cloud LLM)
# ============================================================================
LLM_PROVIDER=ollama  # or groq, openai, gemini
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=60

# ============================================================================
# Ollama Configuration (Production)
# ============================================================================
# Only needed if LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://ollama-production:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# Cloud LLM Providers (Choose one based on LLM_PROVIDER)
# ============================================================================
# GROQ_API_KEY=your_groq_api_key
# GROQ_MODEL=mixtral-8x7b-32768

# OPENAI_API_KEY=your_openai_api_key
# OPENAI_MODEL=gpt-4-turbo

# GOOGLE_API_KEY=your_google_api_key
# GOOGLE_MODEL=gemini-pro

# ============================================================================
# Leadrat CRM Integration (Production URLs use .com domain)
# ============================================================================
LEADRAT_BASE_URL=https://connect.leadrat.com/api/v1
LEADRAT_AUTH_URL=https://connect.leadrat.com/api/v1/authentication/token
LEADRAT_TENANT=dubait11
LEADRAT_API_KEY=your_production_api_key
LEADRAT_SECRET_KEY=your_production_secret_key
LEADRAT_TOKEN_CACHE_TTL=3600

# ============================================================================
# Spring Boot Backend (Production)
# ============================================================================
SPRING_BOOT_URL=https://your-spring-boot-production-url.com
SPRING_BOOT_TIMEOUT_SECONDS=30

# ============================================================================
# Database Configuration (Production PostgreSQL)
# ============================================================================
DATABASE_URL=postgresql+asyncpg://username:password@production-db-host:5432/realestate_db

# ============================================================================
# Redis Configuration (Production)
# ============================================================================
REDIS_URL=redis://production-redis-host:6379
REDIS_DB=0
REDIS_TTL_SECONDS=300

# ============================================================================
# CORS Configuration (Production Frontend Domain)
# ============================================================================
ALLOWED_ORIGINS=https://leadrat-chat-widget.pages.dev,https://your-production-domain.com

# ============================================================================
# Application Configuration
# ============================================================================
CONVERSATION_HISTORY_LIMIT=20
SESSION_TIMEOUT_HOURS=24
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# ============================================================================
# JWT & Security
# ============================================================================
JWT_SECRET_KEY=your_production_jwt_secret_minimum_32_characters_long_min32
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================================================
# Monitoring & Observability (Production)
# ============================================================================
SENTRY_DSN=your_sentry_dsn_url
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
