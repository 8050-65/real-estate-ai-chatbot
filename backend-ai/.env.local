# ============================================================================
# LOCAL DEVELOPMENT ENVIRONMENT - FastAPI Backend
# ============================================================================

# ============================================================================
# Environment Detection
# ============================================================================
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=DEBUG

# ============================================================================
# LLM Provider Selection (Local Ollama)
# ============================================================================
LLM_PROVIDER=ollama
LLM_MODEL=llama3.2
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1000
LLM_TIMEOUT_SECONDS=60

# ============================================================================
# Ollama Configuration (INTERNAL ONLY - Browser never calls this)
# ============================================================================
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ============================================================================
# Leadrat CRM Integration (LOCAL TESTING)
# ============================================================================
LEADRAT_BASE_URL=https://connect.leadrat.com/api/v1
LEADRAT_AUTH_URL=https://connect.leadrat.com/api/v1/authentication/token
LEADRAT_TENANT=dubait11
LEADRAT_API_KEY=Zjg2N2JiNjItODBmOC00YzBjLTlkMmMtMjk5OGRiZjBmMDU3OmR1YmFpdDEx
LEADRAT_SECRET_KEY=a3Ay5UKLYjm6sZ_TXCXGzqmIdB3zgM8Y
LEADRAT_TOKEN_CACHE_TTL=3600

# ============================================================================
# Spring Boot Backend (Local Development)
# ============================================================================
SPRING_BOOT_URL=http://localhost:8080
SPRING_BOOT_TIMEOUT_SECONDS=30

# ============================================================================
# Database Configuration (Local SQLite or PostgreSQL)
# ============================================================================
# Uncomment for local PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://realestate:password@localhost:5432/realestate_db

# Or use SQLite for minimal setup:
DATABASE_URL=sqlite:///./test.db

# ============================================================================
# Redis Configuration (Optional - Session Cache)
# ============================================================================
# REDIS_URL=redis://localhost:6379
# REDIS_DB=0

# ============================================================================
# CORS Configuration (Allow localhost frontend)
# ============================================================================
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8000,http://127.0.0.1:3000,http://127.0.0.1:8000

# ============================================================================
# Application Configuration
# ============================================================================
CONVERSATION_HISTORY_LIMIT=20
SESSION_TIMEOUT_HOURS=24
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=5000

# ============================================================================
# JWT & Security
# ============================================================================
JWT_SECRET_KEY=local_development_secret_minimum_32_chars_long_min32chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24
