# PRODUCTION ENVIRONMENT CONFIGURATION
# Copy this file to .env.production and replace values with your actual URLs

# Widget base URL (where the frontend is deployed)
NEXT_PUBLIC_WIDGET_BASE_URL=https://leadrat-chat-widget.pages.dev

# FastAPI chat endpoint (production Render endpoint)
NEXT_PUBLIC_CHAT_API_URL=https://real-estate-rag-dev.onrender.com/api/v1/chat/message

# FastAPI health check endpoint
NEXT_PUBLIC_CHAT_HEALTH_URL=https://real-estate-rag-dev.onrender.com/api/v1/chat/health

# Spring Boot backend (used by FastAPI internally)
NEXT_PUBLIC_SPRING_BOOT_URL=https://your-spring-boot-production-url.com

# Default tenant ID
NEXT_PUBLIC_DEFAULT_TENANT_ID=dubait11
